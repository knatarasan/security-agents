# ─── LLM Provider ────────────────────────────────────────────────────────────
# Set to "openai" (default) or "anthropic"
MODEL_PROVIDER=openai

# ─── API Keys (set whichever provider you selected above) ────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ─── W&B Evaluation ───────────────────────────────────────────────────────────
# Get your key from https://wandb.ai/authorize
# Alternatively run: wandb login
WANDB_API_KEY=your_wandb_api_key_here
